function applyCustomPrices(){products.forEach(p=>{if(customPrices[p.n])p.p=Number(customPrices[p.n])})}
function saveDraft(){localStorage.setItem('seera_current_invoice',JSON.stringify({cart,paid:paid.value||'',notes:notes.value||'',tableNo:tableNo.value||'',invoiceNo}))}
function loadDraft(){try{let d=JSON.parse(localStorage.getItem('seera_current_invoice')||'null');if(!d)return;cart=d.cart||[];paid.value=d.paid||'';notes.value=d.notes||'';tableNo.value=d.tableNo||'';if(d.invoiceNo){invoiceNo=d.invoiceNo;invNo.textContent=invoiceNo}}catch(e){}}
function svg(type){const cup='<path d="M10 12h18v9a9 9 0 0 1-9 9 9 9 0 0 1-9-9v-9z"/><path d="M28 15h3a4 4 0 0 1 0 8h-3"/><path d="M15 7c0-2 2-2 2-4M21 7c0-2 2-2 2-4"/>';const can='<rect x="13" y="6" width="14" height="28" rx="3"/><path d="M16 10h8M16 30h8"/>';const leaf='<path d="M20 32V16"/><path d="M20 20c-8-2-10-8-9-13 8 0 13 5 9 13z"/><path d="M21 22c7-2 10-7 9-12-7 0-12 5-9 12z"/>';const cake='<path d="M9 18h22v12H9z"/><path d="M11 18c3-8 15-8 18 0"/><path d="M13 23h14"/>';const shisha='<path d="M20 6v20"/><path d="M14 13h12"/><path d="M16 26h8l3 8H13l3-8z"/><path d="M26 13c8 0 8 10 1 10"/>';let inner={coffee:cup,milk:cup,hot:cup,fresh:leaf,ice:can,can:can,cake:cake,shisha:shisha}[type]||cup;return `<svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${inner}</svg>`}
function login(){if(user.value===USER&&pass.value===PASS){localStorage.setItem('seera_login','1');document.getElementById('login').classList.add('hidden');toast('تم تسجيل الدخول')}else toast('بيانات الدخول غير صحيحة')}
function logout(){localStorage.removeItem('seera_login');location.reload()}
function start(){if(localStorage.getItem('seera_login')==='1')loginEl().classList.add('hidden');applyCustomPrices();newInvoice();loadDraft();renderCats();render();updateCart();['paid','notes','tableNo'].forEach(id=>{let el=document.getElementById(id);if(el)el.addEventListener('input',saveDraft)});setInterval(tick,1000);tick()}function loginEl(){return document.getElementById('login')}
function newInvoice(){invoiceNo='#'+String(Math.floor(1000+Math.random()*9000));invNo.textContent=invoiceNo}
function tick(){let d=new Date();clock.textContent=d.toLocaleTimeString('ar-EG',{hour:'2-digit',minute:'2-digit'});date.textContent=d.toLocaleDateString('ar-EG')}
function renderCats(){let cats=['الكل',...new Set(products.map(p=>p.c))];catsEl=document.getElementById('cats');catsEl.innerHTML=cats.map(c=>`<div class="cat ${activeCat===c?'active':''}" onclick="activeCat='${c}';renderCats();render()"><span>${c}</span><span class="cat-count">${c==='الكل'?products.length:products.filter(p=>p.c===c).length}</span></div>`).join('')}
function render(){let q=search.value.trim();let list=products.filter(p=>(activeCat==='الكل'||p.c===activeCat)&&(!q||p.n.includes(q)));catName.textContent=activeCat;catSub.textContent=list.length+' منتج';grid.innerHTML=list.map((p,idx)=>card(p,idx)).join('')+(activeCat==='الكل'?serviceCard():'')}
function card(p,idx){return `<div class="product"><div class="pic">${svg(p.i)}</div><div class="pname">${p.n}</div><div class="price">${p.p} ج</div><div class="qty"><button class="qbtn" onclick="chgQty(${idx},-1)">−</button><b id="q${idx}">1</b><button class="qbtn" onclick="chgQty(${idx},1)">+</button></div><button class="add" onclick='addItem(${JSON.stringify(p)}, Number(document.getElementById("q${idx}").textContent))'>+ إضافة</button><button class="edit-price" onclick='changeProductPrice(${JSON.stringify(p)})'>تغيير السعر</button></div>`}
function changeProductPrice(p){let pass=prompt('اكتب باسورد تعديل السعر');if(pass!==PRICE_PASS)return toast('باسورد تعديل السعر غلط');let val=prompt('السعر الجديد لـ '+p.n, p.p);if(val===null)return;val=Number(val);if(!val||val<=0)return toast('اكتب سعر صحيح');let item=products.find(x=>x.n===p.n);if(item)item.p=val;customPrices[p.n]=val;localStorage.setItem('seera_custom_prices',JSON.stringify(customPrices));cart.forEach(x=>{if(x.n===p.n)x.p=val});render();updateCart();toast('تم تغيير السعر')}
function serviceCard(){return `<div class="product service-card"><div class="pic">${svg('hot')}</div><div class="pname">خدمة إضافية</div><input id="serviceAmount" type="number" placeholder="أدخل المبلغ"><button class="add" onclick="addService()">+ إضافة خدمة</button></div><div class="product service-card"><div class="pic">${svg('hot')}</div><div class="pname">إضافة مشروب</div><input id="customDrinkName" type="text" placeholder="اسم المشروب"><input id="customDrinkPrice" type="number" placeholder="السعر"><button class="add" onclick="addCustomDrink()">+ إضافة مشروب</button></div><div class="product service-card"><div class="pic">${svg('hot')}</div><div class="pname">إضافة نعناع</div><div class="price">5 ج</div><button class="add" onclick="addMintExtra()">+ إضافة للفاتورة</button></div>`}
function addCustomDrink(){let pass=prompt('اكتب باسورد إضافة مشروب');if(pass!==PRICE_PASS)return toast('باسورد إضافة المشروب غلط');let name=(customDrinkName.value||'').trim();let price=Number(customDrinkPrice.value||0);if(!name)return toast('اكتب اسم المشروب');if(!price||price<=0)return toast('اكتب سعر صحيح');addItem({n:name,p:price,c:'مشروب خاص',i:'hot'},1);customDrinkName.value='';customDrinkPrice.value=''}
function addMintExtra(){addItem({n:'إضافة نعناع',p:5,c:'إضافات',i:'hot'},1)}
function chgQty(i,d){let el=document.getElementById('q'+i);el.textContent=Math.max(1,Number(el.textContent)+d)}
function addItem(p,q=1){let x=cart.find(i=>i.n===p.n); if(x)x.q+=q; else cart.push({...p,q}); updateCart();toast('تمت الإضافة')}
function addService(){let v=Number(serviceAmount.value||0); if(v<=0)return toast('اكتب قيمة السيرفس'); addItem({n:'سيرفس',p:v,c:'خدمة',i:'hot'},1); serviceAmount.value=''}
function updateCart(){let box=document.getElementById('cart'); if(!cart.length){box.innerHTML='<div class="empty">لا توجد منتجات<br>ابدأ بإضافة منتجات للفاتورة</div>'}else box.innerHTML=cart.map((i,k)=>`<div class="cart-item"><div class="cart-row"><span class="cart-name">${i.n}</span><button class="remove" onclick="cart.splice(${k},1);updateCart()">حذف</button></div><div class="cart-row"><span>${i.q} × ${i.p} ج</span><span class="cart-total">${i.q*i.p} ج</span></div></div>`).join('');let sub=cart.reduce((s,i)=>s+i.p*i.q,0), cnt=cart.reduce((s,i)=>s+i.q,0), paidVal=Number(paid.value||0), diff=paidVal-sub;subtotal.textContent=sub.toFixed(2)+' ج';total.textContent=sub.toFixed(2)+' ج';itemCount.textContent=cnt;change.textContent=paidVal?diff.toFixed(2)+' ج':'---';saveDraft()}
function clearCart(){cart=[];paid.value='';notes.value='';localStorage.removeItem('seera_current_invoice');updateCart();newInvoice();saveDraft()}
function closeInvoice(){if(!cart.length)return toast('الفاتورة فاضية');let sub=cart.reduce((s,i)=>s+i.p*i.q,0), p=Number(paid.value||0); if(p<sub)return toast('المبلغ المدفوع أقل من الإجمالي');let diff=p-sub; if(diff>0){pendingTip=diff;tipValue.textContent=diff.toFixed(2)+' ج';tipModal.classList.remove('hidden')}else submitInvoice(0)}
async function submitInvoice(tip){tipModal.classList.add('hidden');loader.classList.remove('hidden');let sub=cart.reduce((s,i)=>s+i.p*i.q,0);let payload={invoice_number:invoiceNo,date:new Date().toLocaleDateString('ar-EG'),time:new Date().toLocaleTimeString('ar-EG'),cashier:USER,table_number:tableNo.value||'',items:cart.map(i=>`${i.n} × ${i.q}`).join(' | '),items_count:cart.reduce((s,i)=>s+i.q,0),subtotal:sub,paid:Number(paid.value||0),change_amount:tip,tip_amount:tip,notes:notes.value||'',saved_at:new Date().toISOString()};try{await fetch(GOOGLE_SHEET_API,{method:'POST',mode:'no-cors',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});let local=JSON.parse(localStorage.getItem('seera_orders')||'[]');local.push(payload);localStorage.setItem('seera_orders',JSON.stringify(local));toast('تم حفظ الفاتورة بنجاح');clearCart()}catch(e){toast('تعذر حفظ الفاتورة، تحقق من الاتصال')}finally{loader.classList.add('hidden')}}

function todayKey(){return new Date().toLocaleDateString('ar-EG')}
function parseItems(str){let out=[];(str||'').split('|').forEach(part=>{let clean=part.trim();if(!clean)return;let m=clean.match(/(.+)×\s*(\d+)/);if(m)out.push({name:m[1].trim(),qty:Number(m[2]||0)});});return out}
function getTodayOrders(){let orders=JSON.parse(localStorage.getItem('seera_orders')||'[]');let today=todayKey();return orders.filter(o=>{if(o.saved_at){return new Date(o.saved_at).toLocaleDateString('ar-EG')===today}return o.date===today})}
function openReports(){let orders=getTodayOrders();let sales=orders.reduce((s,o)=>s+Number(o.subtotal||0),0);let tips=orders.reduce((s,o)=>s+Number(o.change_amount||o.tip_amount||0),0);let productMap={};let itemTotal=0;orders.forEach(o=>{parseItems(o.items).forEach(it=>{let unit=0;let p=products.find(x=>x.n===it.name);if(p)unit=p.p;productMap[it.name]=productMap[it.name]||{qty:0,total:0};productMap[it.name].qty+=it.qty;productMap[it.name].total+=it.qty*unit;itemTotal+=it.qty})});rSales.textContent=sales.toFixed(2)+' ج';rInvoices.textContent=orders.length;rTips.textContent=tips.toFixed(2)+' ج';rItems.textContent=itemTotal;let rows=Object.entries(productMap).sort((a,b)=>b[1].qty-a[1].qty).map(([name,v])=>`<tr><td>${name}</td><td>${v.qty}</td><td>${v.total.toFixed(2)} ج</td></tr>`).join('');reportRows.innerHTML=rows||'<tr><td colspan="3" class="report-empty">لسه مفيش فواتير متسجلة النهارده على الجهاز ده</td></tr>';reportModal.classList.remove('hidden')}
function closeReports(){reportModal.classList.add('hidden')}

function escPrint(v){return String(v??'').replace(/[&<>"]/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[m]))}
function printReceipt(){
  if(!cart.length){toast('الفاتورة فاضية');return}
  const sub=cart.reduce((s,i)=>s+(Number(i.p)||0)*(Number(i.q)||0),0);
  const paidVal=Number(paid.value||0);
  const diff=paidVal-sub;
  const rows=cart.map(i=>`<tr><td class="item"><b>${escPrint(i.n)}</b></td><td class="qtycol">${i.q}</td><td class="num">${Number(i.p).toFixed(2)}</td><td class="num totalcol">${(Number(i.p)*Number(i.q)).toFixed(2)}</td></tr>`).join('');
  const now=new Date();
  const receipt=`<!doctype html><html lang="ar" dir="rtl"><head><meta charset="utf-8"><title>فاتورة ${escPrint(invoiceNo)}</title><style>
    @page{size:80mm auto;margin:3mm}
    *{box-sizing:border-box}
    html,body{margin:0;padding:0;background:#fff;color:#111;font-family:Tahoma,Arial,sans-serif}
    body{font-size:12px;line-height:1.5;-webkit-print-color-adjust:exact;print-color-adjust:exact}
    .receipt{width:74mm;margin:0 auto;padding:2mm 1mm;background:#fff}
    .brand{text-align:center;margin-bottom:7px}.brand h1{font-size:22px;letter-spacing:1px;margin:0;font-weight:900}.brand p{font-size:11px;margin:1px 0 0;color:#333}
    .sep{border-top:1.5px dashed #111;margin:7px 0}
    .meta{font-size:11px}.meta .line,.totals .line{display:flex;justify-content:space-between;align-items:center;gap:8px;margin:3px 0}.meta b,.totals b{font-weight:900}
    table{width:100%;border-collapse:collapse;table-layout:fixed;margin-top:4px}th{font-size:11px;font-weight:900;padding:5px 2px;border-bottom:1.5px solid #111}td{padding:5px 2px;border-bottom:1px dashed #aaa;vertical-align:top}
    .item{width:40%;text-align:right;word-wrap:break-word}.qtycol{width:13%;text-align:center;font-weight:900}.num{width:22%;text-align:left;white-space:nowrap}.totalcol{font-weight:900}
    .totals{font-size:12px}.grand{font-size:17px;border-top:1.5px solid #111;padding-top:6px;margin-top:6px}.grand span,.grand b{font-weight:900}
    .thanks{text-align:center;font-size:12px;font-weight:900;margin-top:10px;padding-top:7px;border-top:1.5px dashed #111}
    @media print{body{width:80mm}.receipt{width:74mm}.no-print{display:none!important}}
  </style></head><body><div class="receipt">
    <div class="brand"><h1>SEERA Cafe</h1><p>فاتورة بيع</p></div>
    <div class="sep"></div>
    <div class="meta">
      <div class="line"><span>رقم الفاتورة</span><b>${escPrint(invoiceNo)}</b></div>
      <div class="line"><span>التاريخ</span><b>${now.toLocaleDateString('ar-EG')}</b></div>
      <div class="line"><span>الوقت</span><b>${now.toLocaleTimeString('ar-EG')}</b></div>
      <div class="line"><span>الترابيزة</span><b>${escPrint(tableNo.value||'-')}</b></div>
    </div>
    <div class="sep"></div>
    <table><thead><tr><th class="item">الصنف</th><th class="qtycol">عدد</th><th class="num">سعر</th><th class="num">إجمالي</th></tr></thead><tbody>${rows}</tbody></table>
    <div class="sep"></div>
    <div class="totals">
      <div class="line grand"><span>الإجمالي</span><b>${sub.toFixed(2)} ج</b></div>
      ${paidVal?`<div class="line"><span>المدفوع</span><b>${paidVal.toFixed(2)} ج</b></div><div class="line"><span>${diff>=0?'الباقي':'المتبقي'}</span><b>${Math.abs(diff).toFixed(2)} ج</b></div>`:''}
    </div>
    <div class="thanks">شكراً لزيارتكم</div>
  </div><script>window.onload=function(){setTimeout(function(){window.print();setTimeout(function(){window.close()},350)},180)}<\/script></body></html>`;
  const w=window.open('', '_blank', 'width=420,height=720');
  if(!w){toast('اسمح بفتح النوافذ للطباعة');return}
  w.document.open();w.document.write(receipt);w.document.close();
}

function printReport(){openReports();window.print()}
function clearLocalReports(){if(confirm('متأكد إنك عايز تمسح التقارير المحلية من الجهاز؟ ده مش هيمسح Google Sheet.')){localStorage.removeItem('seera_orders');openReports();toast('تم مسح التقارير المحلية')}}
